<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:aop="http://www.springframework.org/schema/aop"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
            http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd  
            http://www.springframework.org/schema/mvc http://www.springframework.org/schema/mvc/spring-mvc.xsd
            http://www.springframework.org/schema/aop
        	http://www.springframework.org/schema/aop/spring-aop.xsd">
	
	<aop:aspectj-autoproxy />
	<import resource="classpath*:config/**/springApp-*.xml"></import>
    <import resource="classpath*:config/**/springMvc-*.xml"></import>
    
    <context:component-scan base-package="com.iflytek.vie.standard" />
    <context:component-scan base-package="com.iflytek.vie.custom" />
    <mvc:annotation-driven>  
        <mvc:message-converters>  
        	<ref bean="stringHttpMessageConverter" />  
        	<ref bean="mappingJacksonHttpMessageConverter" />  
        </mvc:message-converters>
    </mvc:annotation-driven>  
    
    <!-- 处理JSON数据转换，为了处理返回的JSON数据的编码，默认是ISO-88859-1的，这里把它设置为UTF-8,解决有乱码的情况 -->
    <bean id="mappingJacksonHttpMessageConverter" class="org.springframework.http.converter.json.MappingJackson2HttpMessageConverter">
        <!-- 处理responseBody 里面日期类型--> 
        <property name="objectMapper">  
            <bean class="com.fasterxml.jackson.databind.ObjectMapper">  
                <property name="dateFormat">  
                    <bean class="java.text.SimpleDateFormat">  
                        <constructor-arg type="java.lang.String" value="yyyy-MM-dd HH:mm:ss" />  
                    </bean>  
                </property>  
            </bean>  
        </property>   
        <property name="supportedMediaTypes">
            <list>
                <value>application/json;charset=UTF-8</value>
                <value>application/*+json;charset=UTF-8</value>
                <value>text/json;charset=UTF-8</value>  
            </list>
        </property>
    </bean>
    
    <bean id="stringHttpMessageConverter" class="org.springframework.http.converter.StringHttpMessageConverter">
    	<property name="supportedMediaTypes">
            <list>
                <value>text/html;charset=UTF-8</value>
            </list>
        </property>
    </bean>
    
    <!-- 默认跳转到首页 -->
	<mvc:view-controller path="/" view-name="login" />
    
    <!-- 静态资源过滤 -->
	<mvc:resources mapping="/**" location="/views/" />

    <!-- 配置的是freemarker -->
    <bean id="freemarkerConfig"
		  class="org.springframework.web.servlet.view.freemarker.FreeMarkerConfigurer">
		<property name="templateLoaderPath" value="/views/" />
		<property name="freemarkerSettings">
			<props>
				<prop key="template_update_delay">0</prop>
				<prop key="default_encoding">UTF-8</prop>
				<prop key="number_format">0.##########</prop>
				<prop key="datetime_format">yyyy-MM-dd HH:mm:ss</prop>
				<prop key="classic_compatible">true</prop>
				<prop key="template_exception_handler">ignore</prop>
			</props>
		</property>
	</bean>
	
	<!-- html模板视图解析 -->
	<bean id="viewResolver" class="org.springframework.web.servlet.view.freemarker.FreeMarkerViewResolver">
		<property name="exposeRequestAttributes" value="true" />
		<property name="exposeSessionAttributes" value="true" />
		<property name="viewClass" value="org.springframework.web.servlet.view.freemarker.FreeMarkerView" />
		<property name="cache" value="true" />
		<property name="prefix" value="/" />
		<property name="suffix" value=".html" />
		<property name="contentType" value="text/html; charset=UTF-8" />
		<property name="order" value="0"/>
	</bean>
	
	<!--通用视图解析器    
    <bean id="viewResolverCommon" class="org.springframework.web.servlet.view.InternalResourceViewResolver">    
        <property name="prefix" value="/"/>      
        <property name="suffix" value=".html"/> 
        <property name="viewClass">    
            <value>org.springframework.web.servlet.view.InternalResourceView</value>    
        </property>    
        <property name="order" value="1"/>    
    </bean>-->
    
	<!-- jsp视图解析 
    <bean id="viewJspResolver" class="org.springframework.web.servlet.view.InternalResourceViewResolver">
        <property name="viewClass"
                  value="org.springframework.web.servlet.view.JstlView" />
        <property name="contentType" value="text/html"/>  
        <property name="prefix" value="/views/" />
        <property name="suffix" value=".jsp" />
        <property name="order" value="1"/>    
    </bean> -->
    
    
	<bean id="multipartResolver" class="org.springframework.web.multipart.commons.CommonsMultipartResolver">
       <property name="maxUploadSize" value="104857600"/>
       <property name="maxInMemorySize" value="4096"/>
   </bean>

    <aop:config>
        <aop:aspect id="desensitizationAspect" ref="desensitizationSourceAspect" order="1">
            <aop:pointcut id="desensitizationPointCuts" expression="execution(* com.iflytek.vie.standard.search.SearchController.queryTableSearchList(..))
            or execution(* com.iflytek.vie.standard.search.SearchController.queryTextSearchList(..))
            or execution(* com.iflytek.vie.standard.topic.TopicController.getPathData(..))
            or execution(* com.iflytek.vie.standard.call.CallFilterController.queryCallList(..))
            or execution(* com.iflytek.vie.standard.topic.ClusterController.getTogatherData(..))
            or execution(* com.iflytek.vie.standard.model.ModelController.previewModel(..))
            or execution(* com.iflytek.vie.standard.model.ModelController.previewMarks(..))
            or execution(* com.iflytek.vie.standard.model.ModelController.getTableData(..))
            or execution(* com.iflytek.vie.standard.report.ReportController.getTableData(..))
            or execution(* com.iflytek.vie.standard.home.HomePageController.getTableData(..))
            or execution(* com.iflytek.vie.standard.report.ReportController.getLineColumData(..))
            or execution(* com.iflytek.vie.standard.topic.FunnelController.getFunnelList(..))
            or execution(* com.iflytek.vie.standard.report.ReportController.getPieData(..))"/>
            <aop:around pointcut-ref="desensitizationPointCuts" method="around"/>
        </aop:aspect>
    </aop:config>
    <bean id="desensitizationSourceAspect" class="com.iflytek.vie.filter.DesensitizationInterceptor" />

</beans>

